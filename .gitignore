# ── Secrets & local environment ─────────────────────────────────────────────
.env
.env.local
*.pem
*.key

# ── Virtualenvs / Python caches ─────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── IDE / editor / tooling ──────────────────────────────────────────────────
.claude/
.vscode/
