Stages/post-log.json

# ── Build / dist ────────────────────────────────────────────────────────────
build/
dist/
*.tar.gz
*.zip

# ── Generated pipeline artifacts ────────────────────────────────────────────
# All artifacts live in Artifacts/ and are tracked there.
# Root-level copies are NOT created by the pipeline (only Artifacts/ is written).
# These patterns guard against accidental root-level regeneration:
extracted_content.json
entities.json
entity_sentiment.json
qa_report.json
cost_report.json
run_metrics.json
sentiment_timeline.json
llm_calls.jsonl
reports/

# Keep Artifacts/ tracked — evaluators inspect it for reference output.
# Keep sources.json tracked — it is input, not output.
!sources.json
