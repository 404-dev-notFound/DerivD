# Virtual environments
.venv/
venv/
env/

# Environment files with secrets
.env
.env.*
!.env.example

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Generated pipeline artifacts — all live in Artifacts/ at runtime, never baked in.
# Stale artifacts in the image would cause the pipeline to appear to have run
# when it hasn't (violates the replayability requirement).
Artifacts/
reports/
extracted_content.json
entities.json
entity_sentiment.json
qa_report.json
cost_report.json
run_metrics.json
sentiment_timeline.json
llm_calls.jsonl
pipeline.log

# IDE and OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Planning and docs that don't belong in image
*.plan.md
pre-log.json
post-log.json
