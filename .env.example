# ── Required ────────────────────────────────────────────────────────────────
# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Optional overrides (config.json is the primary source of model config) ──
# Default model when config.json does not specify a tier for a stage.
LLM_MODEL=anthropic/claude-sonnet-4.5

# Per-stage model overrides (override config.json stage tiers).
# Uncomment to force a specific model for one stage:
# LLM_MODEL_ENTITY_EXTRACTION=anthropic/claude-haiku-4.5
# LLM_MODEL_ENTITY_RESOLUTION=anthropic/claude-sonnet-4.5
# LLM_MODEL_ENTITY_SENTIMENT_SCORING=anthropic/claude-sonnet-4.5
# LLM_MODEL_QA_AND_CONFLICT_DETECTION=anthropic/claude-haiku-4.5
# LLM_MODEL_REPORT_GENERATION=anthropic/claude-sonnet-4.5

# Fallback max_tokens when config.json has no per-stage value.
MAX_TOKENS=4096

# ── REST API settings ────────────────────────────────────────────────────────
# REQUIRED to start the API server (api.py will refuse to start without it).
# Use a long random string — e.g.: openssl rand -hex 32
API_SECRET_KEY=change-me-to-a-long-random-string
# Comma-separated CORS origins
ALLOWED_ORIGINS=http://localhost:3000
